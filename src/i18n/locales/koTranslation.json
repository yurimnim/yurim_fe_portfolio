    "cheiron": {
      "title": "PhynxLab \u2014 Cheiron",
      "subtitle": "\uc81c\uc57d\ud68c\uc0ac \uc5f0\uad6c\uc790\ub97c \uc704\ud55c AI \ub17c\ubb38 \ud0d0\uc0c9 \ud50c\ub7ab\ud3fc",
      "description": "Cheiron\uc740 \uc0dd\uc131\ud615 AI\ub97c \ud65c\uc6a9\ud574 \uc81c\uc57d \uc5f0\uad6c\uc790\uac00 \ub300\uaddc\ubaa8 \uacfc\ud559 \ub17c\ubb38\uc744 \ud0d0\uc0c9\u00b7\ubd84\uc11d\u00b7\uc885\ud569\ud560 \uc218 \uc788\ub294 \ud50c\ub7ab\ud3fc\uc785\ub2c8\ub2e4. \ucf54\ub4dc\ubca0\uc774\uc2a4\uc5d0 \uad6c\uc870\uac00 \ud544\uc694\ud55c \uc2dc\uc810\uc5d0 \ud569\ub958\ud558\uc5ec \uc5ec\ub7ec \ud575\uc2ec \uae30\uc220 \uc6cc\ud06c\uc2a4\ud2b8\ub9bc\uc744 \uc8fc\ub3c4\ud588\uc2b5\ub2c8\ub2e4:\n\n\u2022 \uc2e4\uc2dc\uac04 AI \uc751\ub2f5 \ub80c\ub354\ub9c1\uc744 \uc704\ud55c \ucee4\uc2a4\ud140 \uc810\uc9c4\uc801 \uc2a4\ud2b8\ub9ac\ubc0d \ud30c\uc11c \uad6c\ud604 \u2014 \ud14c\uc774\ube14 \ud589 \uae5c\ube61\uc784, x-scroll \uc190\uc2e4, \ub77c\uc774\ube0c \ub370\uc774\ud130 \ud558\uc758 stale remount \ubb38\uc81c \ud574\uacb0\n\u2022 @tanstack/react-virtual\uc744 \ud65c\uc6a9\ud55c \uc0ac\uc774\ub4dc\ubc14 \uac00\uc0c1\ud654\ub85c \ub300\uaddc\ubaa8 \uacb0\uacfc \uc138\ud2b8\uc758 \ub80c\ub354\ub9c1 \uc624\ubc84\ud5e4\ub4dc \ub300\ud3ed \uac10\uc18c\n\u2022 \uac00\uc0c1 \uc694\uc18c \ud3ec\uc9c0\uc154\ub2dd\uacfc scroll-close \ub3d9\uc791\uc73c\ub85c \uc778\uc6a9 \uc2dc\uc2a4\ud15c \uc804\uba74 \uac1c\ud3b8 \u2014 \uc774\uc804 \ub9ac\ud329\ud1a0\ub9c1\uc73c\ub85c \uc778\ud55c \ubdf0\uc5b4 \ub77c\uc6b0\ud305 \ud68c\uadc0 \uc218\uc815\n\u2022 AbortController \uae30\ubc18 \uc694\uccad \ucde8\uc18c\ub97c \ud3ec\ud568\ud55c 4\ub2e8\uacc4 \uc2a4\ud2b8\ub9ac\ubc0d \uc544\ud0a4\ud14d\ucc98 \ud604\ub300\ud654 \uc8fc\ub3c4, \ub2e4\uc74c \ub2e8\uacc4 \uc810\uc9c4\uc801 \ub80c\ub354\ub9c1\uc744 \uc704\ud55c \ud1a0\ud070\ud654 \ud30c\uc2f1 \uc804\ub7b5(Incremark) \ud3c9\uac00\n\u2022 2,000\ud589 \uc774\uc0c1\uc758 SearchForm \ucef4\ud3ec\ub10c\ud2b8\ub97c \ud6c5 \ucd94\ucd9c \ubc29\uc2dd\uc73c\ub85c \ub9ac\ud329\ud1a0\ub9c1\ud558\uc5ec \ud14c\uc2a4\ud2b8 \uc6a9\uc774\uc131 \ud5a5\uc0c1 \ubc0f \ud575\uc2ec \uac80\uc0c9 \ud50c\ub85c\uc6b0 \uc804\ubc18\uc758 \uacb0\ud569\ub3c4 \uac10\uc18c",
      "caseStusy": "Cheiron \u2014 \ucf00\uc774\uc2a4 \uc2a4\ud130\ub514 \uc900\ube44 \uc911"
    },
    "healthcare": {
      "title": "\ud55c\uad6d \uc2a4\ub9c8\ud2b8\ud5ec\uc2a4\ucf00\uc5b4\ud611\ud68c CRO \uc5b4\ub4dc\ubbfc",
      "subtitle": "\uc758\ub8cc\uc9c4\ub4e4\uc758 \uba54\ud0c0\ubc84\uc2a4 \uad50\uc721 \ud50c\ub7ab\ud3fc\uc744 \uc704\ud55c \uc5b4\ub4dc\ubbfc \uc6f9",
      "description": "VR \uae30\uae30\ub97c \ud65c\uc6a9\ud574 \uc758\ub8cc\uc9c4\uc774 \uba54\ud0c0\ubc84\uc2a4 \ud658\uacbd\uc5d0\uc11c \uad50\uc721\ubc1b\uc744 \uc218 \uc788\ub294 \ud50c\ub7ab\ud3fc\uc758 \uc5b4\ub4dc\ubbfc \ud398\uc774\uc9c0 \uac1c\ubc1c\uc5d0 \ud504\ub860\ud2b8\uc5d4\ub4dc \uc5ed\ud560\ub85c \ucc38\uc5ec\ud588\uc2b5\ub2c8\ub2e4. \uc811\uc18d \ucd94\uc774, \uac1c\uc778 \uc9c4\ub3c4\uc728, \uc218\uac15\uc0dd\uc758 \uac15\uc758 \ud3c9\uac00 \ubc0f \uc218\uc5c5\ubcc4 \uc120\ud638\ub3c4 \ud1b5\uacc4\ub97c \ud655\uc778\ud560 \uc218 \uc788\ub294 \ub300\uc2dc\ubcf4\ub4dc\ub97c \uad6c\ud604\ud588\uc2b5\ub2c8\ub2e4. Recharts \ub77c\uc774\ube0c\ub7ec\ub9ac\ub97c \ud65c\uc6a9\ud574 \ub370\uc774\ud130 \uc2dc\uac01\ud654\ub97c \ucee4\uc2a4\ud130\ub9c8\uc774\uc9d5\ud558\uc5ec \uc9c1\uad00\uc801\uc774\uace0 \uc720\ub824\ud55c UI\ub97c \uc81c\uacf5\ud588\uc2b5\ub2c8\ub2e4. \ubc30\ud3ec \ud6c4 \uc0ac\uc6a9\uc790 \ud53c\ub4dc\ubc31\uc744 \ubc18\uc601\ud574 \uae30\ub2a5\uc744 \ucd94\uac00 \ubc0f \uac1c\uc120\ud558\uba70 \ud504\ub85c\uc81d\ud2b8\ub97c \uc9c0\uc18d\uc801\uc73c\ub85c \ubc1c\uc804\uc2dc\ucf30\uc2b5\ub2c8\ub2e4."
    },
    "education": {
      "title": "\uc2a4\ub9c8\ud2b8 \ud5ec\uc2a4\ucf00\uc5b4 \uad50\uc721 \ud648\ud398\uc774\uc9c0",
      "subtitle": "\uc758\ub8cc\uc9c4\uc744 \uc704\ud55c \uba54\ud0c0\ubc84\uc2a4 \uad50\uc721 \uc0dd\uc131 \ubc0f \uad00\ub9ac \ud398\uc774\uc9c0",
      "description": "VR \uba54\ud0c0\ubc84\uc2a4 \uad50\uc721\uc744 \uc0dd\uc131\ud558\uace0 \uad00\ub9ac\ud560 \uc218 \uc788\ub294 \uad50\uc721 \uad00\ub9ac \ud50c\ub7ab\ud3fc\uc744 \uac1c\ubc1c\ud588\uc2b5\ub2c8\ub2e4. \uba54\uc778 \uc778\ud2b8\ub85c \ud398\uc774\uc9c0, \uac15\uc758 \uc0dd\uc131, \uc218\uac15 \uc778\uc6d0 \ucd94\uac00, \uac15\uc758 \uc790\ub8cc \uc5c5\ub85c\ub4dc \ubc0f \uad00\ub9ac, \uac15\uc758 \uc815\ubcf4 \uc870\ud68c \ub4f1 \uc8fc\uc694 \uae30\ub2a5\uc744 \uad6c\ud604\ud588\uc2b5\ub2c8\ub2e4. \ucf54\ub4dc \uc2a4\ud50c\ub9ac\ud305\uacfc React Suspense, \uc2a4\ucf08\ub808\ud1a4 \ud654\uba74\uc744 \ub3c4\uc785\ud574 \uac15\uc758 \uc790\ub8cc \uc5c5\ub85c\ub4dc \uc2dc \ubc1c\uc0dd\ud558\ub294 \ub51c\ub808\uc774\uc640 \ud654\uba74 \ubd88\uc548\uc815\uc744 \ud6a8\uacfc\uc801\uc73c\ub85c \uac1c\uc120\ud558\uc5ec \uc0ac\uc6a9\uc790 \uacbd\ud5d8\uc744 \ud5a5\uc0c1\uc2dc\ucf30\uc2b5\ub2c8\ub2e4. \ubc30\ud3ec \uc774\ud6c4 \ud074\ub77c\uc774\uc5b8\ud2b8\ub85c\ubd80\ud130 \uae0d\uc815\uc801\uc778 \ud53c\ub4dc\ubc31\uc744 \ubc1b\uc558\uc2b5\ub2c8\ub2e4."
    },
    "kongju": {
      "title": "\uacf5\uc8fc\ub300\ud559\uad50 \uc608\uc220\ub300\ud559 \uba54\ud0c0\ubc84\uc2a4 \uad50\uc721 \ud648\ud398\uc774\uc9c0",
      "subtitle": "\ub300\ud559\uad50 \uc6d0\uaca9 \uc6f9\uba54\ud0c0\ubc84\uc2a4 \uac15\uc758 \ubc0f \uc218\uc5c5\uad00\ub9ac \uc11c\ube44\uc2a4",
      "description": "\uacf5\uc8fc\ub300\ud559\uad50 \uc608\uc220\ub300\ud559 \ud559\uc0dd\ub4e4\uc744 \uc704\ud55c \uc6d0\uaca9 \uc6f9 \uba54\ud0c0\ubc84\uc2a4 \uac15\uc758 \ubc0f \uc218\uc5c5 \uad00\ub9ac \ud648\ud398\uc774\uc9c0\ub97c \uac1c\ubc1c\ud588\uc2b5\ub2c8\ub2e4. \ub85c\uadf8\uc778, \ucc44\ud305, \uc218\uc5c5 \ub0b4 \ubbf8\ub2c8\uac8c\uc784, \uac15\uc758 \uc790\ub8cc \uc870\ud68c \ubc0f \uad00\ub9ac \ub4f1 \uc8fc\uc694 \uae30\ub2a5\uc744 \uad6c\ud604\ud588\uc2b5\ub2c8\ub2e4. \uc2e4\uc2dc\uac04 \ucc44\ud305\uacfc \ucc38\uc5ec\ud615 \ubbf8\ub2c8\uac8c\uc784\uc744 \uc704\ud574 \ub9ac\uc5bc\ud0c0\uc784 \uc11c\ubc84 \ud1b5\uc2e0\uc744 \uc5f0\uacb0\ud558\uace0 \uc801\uc6a9\ud588\uc2b5\ub2c8\ub2e4. \ucc44\ud305 \ud654\uba74\uc758 \ubd88\ud544\uc694\ud55c \ub80c\ub354\ub9c1\uacfc \uae5c\ube61\uc784\uc744 \ubc29\uc9c0\ud558\uae30 \uc704\ud574 React.memo\uc640 useCallback\uc744 \ud65c\uc6a9\ud574 \ucd5c\uc801\ud654\ub97c \uc9c4\ud589\ud588\uc2b5\ub2c8\ub2e4. \ub610\ud55c \uc0ac\ub2e4\ub9ac \uac8c\uc784\uc5d0\uc11c \ub79c\ub364 \uc778\uc6d0 \ubc30\uc815\uacfc \uc2e4\uc2dc\uac04 \uacb0\uacfc \ud655\uc778 \uae30\ub2a5\uc744 \uad6c\ud604\ud558\uae30 \uc704\ud574 \ubc31\uc5d4\ub4dc \uac1c\ubc1c\uc790\uc640 \uae34\ubc00\ud788 \ud611\uc5c5\ud558\uba70 \ub9e4\ub044\ub7fd\uac8c \ub3d9\uc791\ud558\ub3c4\ub85d \uac1c\ubc1c\ud588\uc2b5\ub2c8\ub2e4."
    },
    "itall": {
      "title": "\uc787\uc62c \uc2a4\ud30c\ub974\ud0c0 \uc5b4\ub4dc\ubbfc",
      "subtitle": "\uc804\uad6d 100\uc5ec\uac1c \uad00\ub9ac\ud615 \ub3c5\uc11c\uc2e4 \ud559\uc0dd\uad00\ub9ac\ub97c \uc704\ud55c \uc5b4\ub4dc\ubbfc \uc6f9",
      "description": "\uad00\ub9ac\ud615 \ub3c5\uc11c\uc2e4\uc744 \uc704\ud55c \uc5b4\ub4dc\ubbfc \ud398\uc774\uc9c0 \uac1c\ubc1c\uc5d0 \ud300\uc6d0\ub4e4\uacfc \ud568\uaed8 \ucc38\uc5ec\ud588\uc2b5\ub2c8\ub2e4. \uc548\ub0b4 \ubc0f CS \uae30\ub2a5, \ud559\uc0dd \uc54c\ub9bc \uae30\ub2a5 \ub4f1 \uc8fc\uc694 \uae30\ub2a5\uc744 \uad6c\ud604\ud558\ub294 \ub370 \uae30\uc5ec\ud588\uc73c\uba70, \uc571 \uc0ac\uc6a9\uc790\uac00 \ubcf4\ub0b8 SOS \uc54c\ub9bc\uc774 \uc6f9\uc5d0\uc11c \uc2e4\uc2dc\uac04\uc73c\ub85c \uc804\ub2ec\ub418\ub3c4\ub85d \uc18c\ucf13 \uc5f0\uacb0\uc744 \ud1b5\ud574 \uc54c\ub78c \uc2dc\uc2a4\ud15c\uc744 \uac1c\ubc1c\ud588\uc2b5\ub2c8\ub2e4. \uc774\ubbf8\uc9c0 \ub9ac\uc2a4\ud2b8 \ub85c\ub529 \ucd5c\uc801\ud654 \uc791\uc5c5\uc5d0 \ucc38\uc5ec\ud574 \uc131\ub2a5\uc744 \uac1c\uc120\ud588\uc73c\uba70, \ud300\uc6d0\ub4e4\uacfc \ud568\uaed8 \ubaa8\ub178\ub808\ud3ec \uad6c\uc870\uc640 \uc544\ud1a0\ubbf9 \ub514\uc790\uc778 \ud328\ud134\uc744 \ub3c4\uc785\ud574 \ucf54\ub4dc\uc758 \uc7ac\uc0ac\uc6a9\uc131\uacfc \uc720\uc9c0\ubcf4\uc218\uc131\uc744 \ub192\uc600\uc2b5\ub2c8\ub2e4."
    }
  }
